# Copy this file to .env.h200 on every physical H200 node.
# RAY_HEAD_IP is identical on every node; NODE_IP is the current node's IP.

COMPOSE_PROJECT_NAME=verl-h200
H200_ENV_FILE=.env.h200

# Prebuilt vLLM image documented by this repository. Change this when your
# cluster maintains a pinned internal image.
VERL_BASE_IMAGE=verlai/verl:vllm017.latest
VERL_IMAGE=ghcr.io/qingtianrobot/verl:h200-latest
VERL_PULL_POLICY=missing

# Ray cluster network.
RAY_HEAD_IP=10.0.0.10
NODE_IP=10.0.0.10
RAY_PORT=6379
RAY_DASHBOARD_PORT=8265

# Typical H200 SXM node defaults. Set these to the real node resources.
GPUS_PER_NODE=8
CPUS_PER_NODE=128
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Use shared storage when possible. These directories must already exist on
# every node before docker compose up.
DATA_DIR=/mnt/shared/verl/data
MODEL_DIR=/mnt/shared/verl/models
CHECKPOINT_DIR=/mnt/shared/verl/checkpoints
HF_CACHE_DIR=/mnt/shared/verl/huggingface

# Conservative NCCL defaults. NCCL auto-detects NVLink and InfiniBand devices.
# Set socket/HCA/GID values according to the cluster administrator's topology.
NCCL_DEBUG=WARN
NCCL_IB_DISABLE=0
NCCL_SOCKET_IFNAME=^lo,docker0,veth

# Optional cluster-specific overrides. Uncomment only after checking the host.
# GLOO_SOCKET_IFNAME=bond0
# NCCL_IB_HCA=mlx5_0,mlx5_1,mlx5_2,mlx5_3,mlx5_4,mlx5_5,mlx5_6,mlx5_7
# NCCL_IB_GID_INDEX=3
# NCCL_CROSS_NIC=0
